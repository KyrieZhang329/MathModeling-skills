{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Method Plan",
  "type": "object",
  "$defs": {
    "string_array": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "model_spec": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "reason": {
          "$ref": "#/$defs/string_array"
        },
        "selection_reason": {
          "$ref": "#/$defs/string_array"
        },
        "required_data": {
          "$ref": "#/$defs/string_array"
        },
        "expected_output": {
          "$ref": "#/$defs/string_array"
        },
        "limitations": {
          "$ref": "#/$defs/string_array"
        },
        "condition": {
          "type": "string"
        },
        "risk": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "rejected_method": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "reason"
      ],
      "additionalProperties": false
    },
    "candidate_scheme": {
      "type": "object",
      "properties": {
        "scheme_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "core_methods": {
          "$ref": "#/$defs/string_array"
        },
        "strengths": {
          "$ref": "#/$defs/string_array"
        },
        "weaknesses": {
          "$ref": "#/$defs/string_array"
        },
        "fit_reason": {
          "type": "string"
        },
        "implementation_risk": {
          "type": "string"
        }
      },
      "required": [
        "scheme_id",
        "name"
      ],
      "additionalProperties": false
    }
  },
  "properties": {
    "method_plan_summary": {
      "type": "object",
      "properties": {
        "overall_strategy": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "implementation_priority": {
          "$ref": "#/$defs/string_array"
        }
      },
      "additionalProperties": false
    },
    "implementation": {
      "type": "object",
      "properties": {
        "target": {
          "type": "string",
          "enum": [
            "python",
            "matlab"
          ]
        },
        "runtime_notes": {
          "$ref": "#/$defs/string_array"
        },
        "script_style": {
          "type": "string"
        },
        "result_format": {
          "$ref": "#/$defs/string_array"
        },
        "figure_format": {
          "$ref": "#/$defs/string_array"
        },
        "random_seed_required": {
          "type": "boolean"
        }
      },
      "required": [
        "target"
      ],
      "additionalProperties": false
    },
    "subproblem_methods": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "problem_type": {
            "type": "string"
          },
          "candidate_schemes": {
            "type": "array",
            "minItems": 2,
            "maxItems": 4,
            "items": {
              "$ref": "#/$defs/candidate_scheme"
            }
          },
          "recommended_scheme_id": {
            "type": "string"
          },
          "required_output": {
            "$ref": "#/$defs/string_array"
          },
          "baseline_model": {
            "$ref": "#/$defs/model_spec"
          },
          "main_model": {
            "$ref": "#/$defs/model_spec"
          },
          "improved_model": {
            "$ref": "#/$defs/model_spec"
          },
          "rejected_methods": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/rejected_method"
            }
          },
          "expected_figures_tables": {
            "$ref": "#/$defs/string_array"
          },
          "expected_artifacts": {
            "$ref": "#/$defs/string_array"
          },
          "implementation_difficulty": {
            "type": "string"
          },
          "validation_plan": {
            "$ref": "#/$defs/string_array"
          },
          "robustness_plan": {
            "$ref": "#/$defs/string_array"
          }
        },
        "required": [
          "id",
          "problem_type",
          "candidate_schemes",
          "recommended_scheme_id",
          "required_output",
          "baseline_model",
          "main_model",
          "improved_model",
          "rejected_methods",
          "expected_artifacts",
          "validation_plan",
          "robustness_plan"
        ],
        "additionalProperties": false
      }
    },
    "dependency_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "artifact_needed": {
            "type": "string"
          }
        },
        "required": [
          "from",
          "to",
          "artifact_needed"
        ],
        "additionalProperties": false
      }
    },
    "data_requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "subquestion": {
            "type": "string"
          },
          "required_data": {
            "$ref": "#/$defs/string_array"
          },
          "missing_data": {
            "$ref": "#/$defs/string_array"
          },
          "data_risks": {
            "$ref": "#/$defs/string_array"
          }
        },
        "required": [
          "subquestion",
          "required_data",
          "missing_data",
          "data_risks"
        ],
        "additionalProperties": false
      }
    },
    "validation_plan": {
      "$ref": "#/$defs/string_array"
    },
    "robustness_plan": {
      "$ref": "#/$defs/string_array"
    },
    "rejected_methods": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rejected_method"
      }
    },
    "implementation_notes": {
      "$ref": "#/$defs/string_array"
    },
    "recommended_next_skill": {
      "type": "string"
    }
  },
  "required": [
    "method_plan_summary",
    "implementation",
    "subproblem_methods",
    "dependency_plan",
    "data_requirements",
    "validation_plan",
    "robustness_plan",
    "rejected_methods",
    "implementation_notes",
    "recommended_next_skill"
  ],
  "additionalProperties": false
}
